# ============================================================
#  LifeTrack — .gitignore
#  Covers: .NET / ASP.NET Core APIs  +  Angular Frontend
# ============================================================


# ── .NET / ASP.NET Core ──────────────────────────────────────

## Build outputs
bin/
obj/
out/

## NuGet packages
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.assets.json
*.lock.json

## Visual Studio / Rider artifacts
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates
.idea/

## Rider / ReSharper
_ReSharper*/
*.DotSettings.user

## Test results
TestResults/
*.trx
*.coverage
*.coveragexml
coverage*/

## Published output
publish/
**/publish/

## EF Core Migrations temp
*.ef.json

## Logs
*.log
logs/
*.log.*

## User secrets
secrets.json
appsettings.Development.json
appsettings.Local.json

## Windows thumbnails
Thumbs.db
Desktop.ini


# ── Angular / Node.js ────────────────────────────────────────

## Node modules (never commit)
node_modules/
jspm_packages/

## Angular build output
Lifetrack.UI/dist/
Lifetrack.UI/.angular/

## Environment files (contain API URLs / keys)
Lifetrack.UI/src/environments/environment.prod.ts
Lifetrack.UI/src/environments/environment.development.ts

## npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*
.yarn/

## TypeScript incremental build
*.tsbuildinfo

## Angular cache
.angular/


# ── Secrets & Credentials ────────────────────────────────────

## Never commit secrets
*.pfx
*.p12
*.key
*.pem
*.env
.env
.env.*
appsettings.*.json
!appsettings.json
!appsettings.Development.json


# ── OS generated ─────────────────────────────────────────────

## macOS
.DS_Store
.AppleDouble
.LSOverride

## Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

## Linux
*~


# ── Miscellaneous ────────────────────────────────────────────

## Compressed files
*.zip
*.tar.gz
*.rar

## Docker overrides (keep Dockerfile, ignore local overrides)
docker-compose.override.yml
